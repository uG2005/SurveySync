<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= labNumber %> — Seat Map | SurveySync</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: #f0f2f5;
            min-height: 100vh;
        }

        /* ── Header ── */
        header {
            width: 100%;
            padding: 12px 20px;
            background-color: #007BFF;
            color: white;
            text-align: center;
            font-size: 22px;
            font-weight: 600;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .back-link {
            font-size: 22px;
            color: white;
            text-decoration: none;
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
        }

        .back-link:hover {
            color: #f78409;
            filter: drop-shadow(1px 1px 8px black);
        }

        .view-toggle {
            font-size: 13px;
            color: white;
            text-decoration: none;
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            border: 1px solid rgba(255, 255, 255, 0.6);
            padding: 5px 14px;
            border-radius: 20px;
            transition: background 0.2s;
        }

        .view-toggle:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        /* ── Stats bar ── */
        .stats-bar {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 56px;
            padding: 14px 10px 6px;
        }

        .stat {
            font-size: 13px;
            font-weight: 600;
            padding: 5px 16px;
            border-radius: 20px;
        }

        .stat.help-stat {
            background: #fff3cd;
            color: #856404;
            border: 1px solid #ffc107;
        }

        .stat.unresolved-stat {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        /* ── Room container ── */
        .room {
            max-width: 960px;
            margin: 10px auto 80px;
            background: #ffffff;
            border: 2px solid #dee2e6;
            border-radius: 14px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        }

        /* ── Whiteboard ── */
        .whiteboard {
            background: linear-gradient(135deg, #2c3e50, #34495e);
            color: #ecf0f1;
            text-align: center;
            padding: 14px;
            font-weight: 600;
            font-size: 15px;
            letter-spacing: 3px;
            text-transform: uppercase;
            border-bottom: 3px solid #1a252f;
        }

        /* ── Seat grid ── */
        .seat-grid {
            display: grid;
            grid-template-columns: <%= gridTemplateColumns %>;
            gap: 8px 6px;
            padding: 24px 20px;
            justify-items: center;
        }

        /* ── Individual seat ── */
        .seat {
            width: 100%;
            min-width: 50px;
            min-height: 55px;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 16px;
            cursor: default;
            transition: transform 0.2s, box-shadow 0.2s;
            position: relative;
            user-select: none;
        }

        .seat .seat-number {
            line-height: 1;
        }

        .seat .seat-sub {
            font-size: 10px;
            font-weight: 400;
            opacity: 0.75;
            margin-top: 3px;
            max-width: 100%;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            padding: 0 4px;
        }

        /* ── Seat states ── */
        .seat.idle {
            background: #e8eaed;
            color: #5f6368;
            border: 2px solid #dadce0;
        }

        .seat.help {
            background: #f7a009;
            color: #fff;
            border: 2px solid #e6940a;
            cursor: pointer;
            animation: pulse 1.5s ease-in-out infinite;
            box-shadow: 0 0 14px rgba(247, 160, 9, 0.45);
        }

        .seat.help:hover {
            transform: scale(1.1);
            box-shadow: 0 0 28px rgba(247, 160, 9, 0.7);
        }

        .seat.unresolved {
            background: #ff4d4d;
            color: #fff;
            border: 2px solid #e03e3e;
            box-shadow: 0 0 10px rgba(255, 77, 77, 0.3);
        }

        @keyframes pulse {

            0%,
            100% {
                transform: scale(1);
                box-shadow: 0 0 10px rgba(247, 160, 9, 0.4);
            }

            50% {
                transform: scale(1.06);
                box-shadow: 0 0 25px rgba(247, 160, 9, 0.7);
            }
        }

        /* ── Legend ── */
        .legend {
            display: flex;
            justify-content: center;
            gap: 22px;
            padding: 14px 10px 18px;
            border-top: 1px solid #eee;
            flex-wrap: wrap;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: #555;
        }

        .legend-dot {
            width: 14px;
            height: 14px;
            border-radius: 5px;
        }

        .legend-dot.idle {
            background: #e8eaed;
            border: 1px solid #dadce0;
        }

        .legend-dot.help {
            background: #f7a009;
        }

        .legend-dot.unresolved {
            background: #ff4d4d;
        }

        /* ── Issue classification overlay ── */
        .overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.4);
            z-index: 1500;
        }

        .overlay.active {
            display: block;
        }

        .issue-panel {
            display: none;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: white;
            border-radius: 16px;
            padding: 24px 28px;
            box-shadow: 0 12px 48px rgba(0, 0, 0, 0.3);
            z-index: 2000;
            min-width: 300px;
            text-align: center;
        }

        .issue-panel.active {
            display: block;
        }

        .issue-panel h3 {
            margin-bottom: 18px;
            font-size: 17px;
            color: #333;
        }

        .issue-btn {
            display: block;
            width: 100%;
            padding: 12px;
            margin: 6px 0;
            background: #f0f2f5;
            border: 1px solid #ddd;
            border-radius: 10px;
            font-family: 'Montserrat', sans-serif;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .issue-btn:hover {
            background: #007BFF;
            color: white;
            border-color: #0056b3;
        }

        .issue-cancel {
            margin-top: 14px;
            color: #999;
            cursor: pointer;
            font-size: 13px;
        }

        .issue-cancel:hover {
            color: #333;
        }

        /* ── Footer ── */
        footer {
            font-size: 14px;
            color: white;
            background-color: #007BFF;
            padding: 10px;
            text-align: center;
            width: 100%;
            position: fixed;
            bottom: 0;
            left: 0;
        }
    </style>
</head>

<body>
    <header>
        <a class="back-link" href="/">&#x21a9;</a>
        <%= labNumber %> — Seat Map
        <a class="view-toggle" href="/lab/<%= labID %>">List View</a>
    </header>

    <div class="stats-bar">
        <div class="stat help-stat">&#x26A0; Active Helps: <%= activeHelps %></div>
        <div class="stat unresolved-stat">&#x2716; Unresolved: <%= unresolvedCount %></div>
    </div>

    <div class="room">
        <div class="whiteboard">&#x1f4cb; Whiteboard</div>

        <div class="seat-grid">
            <% seats.forEach(function(seat) { %>
                <div class="seat <%= seat.status %>"
                     style="grid-column: <%= seat.gridColumn %>; grid-row: <%= seat.gridRow %>;"
                     <% if (seat.status === 'help') { %>
                         onclick="openIssuePanel('<%= seat.tableID %>', '<%= seat.helpStarted %>')"
                     <% } %>
                     title="Table <%= seat.tableID %><% if (seat.status === 'help') { %> — Needs Help<% } else if (seat.status === 'unresolved') { %> — <%= seat.issue %><% } %>"
                >
                    <span class="seat-number"><%= seat.displayID %></span>
                    <% if (seat.status === 'unresolved' && seat.issue) { %>
                        <span class="seat-sub"><%= seat.issue %></span>
                    <% } %>
                    <% if (seat.status === 'help' && seat.helpTime) { %>
                        <span class="seat-sub"><%= seat.helpTime %></span>
                    <% } %>
                </div>
            <% }); %>
        </div>

        <div class="legend">
            <div class="legend-item">
                <div class="legend-dot idle"></div> Idle
            </div>
            <div class="legend-item">
                <div class="legend-dot help"></div> Help Requested
            </div>
            <div class="legend-item">
                <div class="legend-dot unresolved"></div> Unresolved Issue
            </div>
        </div>
    </div>

    <!-- Issue classification modal -->
    <div class="overlay" id="overlay" onclick="closeIssuePanel()"></div>
    <div class="issue-panel" id="issuePanel">
        <h3>Log Issue for Table <span id="issuePanelTable"></span></h3>
        <button class="issue-btn" onclick="logIssue('Faulty Trainer Kit')">Faulty Trainer Kit</button>
        <button class="issue-btn" onclick="logIssue('Faulty Equipment')">Faulty Equipment</button>
        <button class="issue-btn" onclick="logIssue('Wrong Instructions')">Wrong Instructions</button>
        <button class="issue-btn" onclick="logIssue('Wifi Connectivity')">Wifi Connectivity</button>
        <button class="issue-btn" onclick="logIssue('Others/Indeterminate')">Others/Indeterminate</button>
        <div class="issue-cancel" onclick="closeIssuePanel()">Cancel</div>
    </div>

    <footer>Made by Chirag Sehgal</footer>

    <script>
        let selectedTableID = null;
        let selectedTime = null;

        function openIssuePanel(tableID, helpStarted) {
            selectedTableID = tableID;
            selectedTime = helpStarted;
            document.getElementById('issuePanelTable').textContent = tableID;
            document.getElementById('issuePanel').classList.add('active');
            document.getElementById('overlay').classList.add('active');
        }

        function closeIssuePanel() {
            document.getElementById('issuePanel').classList.remove('active');
            document.getElementById('overlay').classList.remove('active');
            selectedTableID = null;
            selectedTime = null;
        }

        function logIssue(issue) {
            if (!selectedTableID) return;

            fetch('/log-issue', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    tableID: selectedTableID,
                    issue: issue,
                    time: selectedTime
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    closeIssuePanel();
                    location.reload();
                } else {
                    alert('Failed to log issue');
                }
            })
            .catch(error => {
                console.error('Error logging issue:', error);
                alert('Error logging issue');
            });
        }

        // Auto-refresh every 10 seconds
        setTimeout(function () {
            location.reload();
        }, 10000);
    </script>
</body>

</html>
